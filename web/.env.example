# Copy to .env.local and adjust. All are optional — sensible testnet
# defaults are baked into src/config.ts.

# The factory contract the app reads circles from. Defaults to the deployed
# testnet factory recorded in deployments/testnet.json.
VITE_FACTORY_ID=CBOOAEERB5DOTXXMZKURAVQXJQYTGMCJCSJWYQSPKVEWB5BSE5ZYRQMK

# The on-chain feedback registry. Feedback is a signed transaction, so
# responses aggregate on the ledger — no backend needed.
VITE_FEEDBACK_ID=CA3FBYWIJUJPUSU7I75M343FEDGLXNXPXIF4QUUAKKZK5NZLPETSETO7

# Optional: forward analytics events to your own endpoint via sendBeacon.
# Leave unset to keep every event local to the browser (the default).
# VITE_ANALYTICS_URL=https://your-collector.example.com/events
